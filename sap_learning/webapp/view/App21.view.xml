<mvc:View
    controllerName="saplearning.saplearning.controller.App21"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox
        class="sapUiSmallMargin"
        width="100%"
        alignItems="Center"
        justifyContent="Center">

        <Title text="VBox / HBox Alignment" class="sapUiSmallMarginBottom"/>

        <!-- HBox for horizontal alignment -->
        <HBox
            width="100%"
            justifyContent="SpaceBetween"
            alignItems="Center"
            class="sapUiSmallMarginBottom">

            <Button text="Left" />
            <Button text="Center" />
            <Button text="Right" />

        </HBox>

        <!-- Center aligned VBox -->
        <VBox
            width="100%"
            alignItems="Center"
            justifyContent="Center"
            class="sapUiSmallMarginTop">

            <Text text="Centered Content" />
            <Button text="Action" />

        </VBox>

    </VBox>
</mvc:View>