<mvc:View
    controllerName="saplearning.saplearning.controller.App13"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox class="sapUiSmallMargin" width="22rem">

        <Title text="Multi-Field Validation" class="sapUiSmallMarginBottom" />

        <Input
            id="nameInput1"
            value="{/name}"
            placeholder="Enter name"
            class="sapUiSmallMarginBottom" />

        <Input
            id="emailInput1"
            value="{/email}"
            placeholder="Enter email"
            class="sapUiSmallMarginBottom" />

        <Button
            text="Validate"
            type="Emphasized"
            press="onValidate" />

    </VBox>
</mvc:View>