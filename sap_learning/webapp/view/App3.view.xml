<mvc:View
    controllerName="saplearning.saplearning.controller.App3"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox class="sapUiSmallMargin" width="20rem">

        <Title text="Max Length Validation" class="sapUiSmallMarginBottom"/>

        <Input
            id="inputField1"
            value="{/inputText}"
            liveChange="onLiveChange"
            placeholder="Max 10 characters"/>

        <Text
            text="Length: {/length}"
            class="sapUiSmallMarginTop" />

    </VBox>
</mvc:View>