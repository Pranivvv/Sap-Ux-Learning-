<mvc:View
    controllerName="saplearning.saplearning.controller.App10"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox class="sapUiSmallMargin" width="20rem">

        <Title text="Number Only Input" class="sapUiSmallMarginBottom"/>

        <Input
            id="numberInput"
            value="{/number}"
            liveChange="onLiveChange"
            placeholder="Enter numbers only" />

    </VBox>
</mvc:View>