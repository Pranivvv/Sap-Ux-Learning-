<mvc:View
    controllerName="saplearning.saplearning.controller.App22"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout">

    

    <VBox class="sapUiSmallMargin">
        <Title text="Responsive Layout using FlexBox" class="sapUiSmallMarginBottom" />

        <l:ResponsiveFlowLayout>
            <Panel headerText="Box 1" width="18rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <content>
                    <Text text="First responsive box" />
                </content>
            </Panel>

            <Panel headerText="Box 2" width="18rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <content>
                    <Text text="Second responsive box" />
                </content>
            </Panel>

            <Panel headerText="Box 3" width="18rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <content>
                    <Text text="Third responsive box" />
                </content>
            </Panel>
        </l:ResponsiveFlowLayout>
    </VBox>
</mvc:View>